{
    "name": "@toolreport/designer",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "main": "./dist/toolreport-designer.umd.cjs",
    "module": "./dist/toolreport-designer.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/toolreport-designer.js",
            "require": "./dist/toolreport-designer.umd.cjs"
        },
        "./dist/*": "./dist/*"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "dev": "vite",
        "build": "vue-tsc --noEmit && vite build",
        "build:lib": "vite build",
        "preview": "vite preview",
        "test": "vitest run",
        "typecheck": "vue-tsc --noEmit"
    },
    "dependencies": {
        "@tailwindcss/vite": "^4.3.0",
        "axios": "^1.7",
        "pinia": "^3.0",
        "vue": "^3.5"
    },
    "devDependencies": {
        "@vitejs/plugin-vue": "^5.2",
        "@vue/test-utils": "^2.4",
        "@vue/tsconfig": "^0.7",
        "jsdom": "^26.0",
        "typescript": "^5.7",
        "vite": "^6.0",
        "vite-plugin-dts": "^4.5",
        "vitest": "^3.0",
        "vue-tsc": "^2.2"
    }
}
